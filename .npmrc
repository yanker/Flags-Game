# @vite-pwa/astro@1.2.0 aún declara su peerDependency de astro hasta ^5.0.0,
# pero es un wrapper fino sobre vite-plugin-pwa y funciona con Astro 6 / Vite 7.
# Esto evita un error ERESOLVE en `npm install` (local y en Vercel) hasta que
# actualicen el rango peer. Quitar cuando @vite-pwa/astro soporte ^6 oficialmente.
legacy-peer-deps=true
